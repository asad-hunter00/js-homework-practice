sidebar.onchange = async () => {
    let res = await fetch(API_LINK)
    let data = await res.json()

    if (sidebar.value !== "all") {
        data = data.filter(item =>
            item.category === sidebar.value
        )
    }

    showData(data)
}





level.onchange = async () => {
    let res = await fetch(API_LINK)
    let data = await res.json()

    if (level.value !== "all") {
        data = data.filter(item =>
            item.difficulty === level.value
        )
    }

    showData(data)
}





search.oninput = async () => {
    let res = await fetch(API_LINK)
    let data = await res.json()

    let filtered = data.filter(item =>
        item.name.toLowerCase().includes(search.value.toLowerCase())
    )

    showData(filtered)
}





<select id="level">
