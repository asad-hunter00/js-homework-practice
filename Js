<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Product Inventory</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <header>
        <h2>Product Inventory</h2>
        <button id="addBtn">+ Add Product</button>
    </header>

    <div id="cards"></div>

    <div class="modal" id="modal">
        <div class="modal-content">
            <h3 id="modalTitle">Add Product</h3>

            <form id="form">

                <input type="text" id="name" placeholder="Product Name" required>

                <div class="row">
                    <input type="text" id="category" placeholder="Category" required>
                    <input type="number" id="price" placeholder="Price" required>
                </div>

                <div class="row">
                    <input type="number" id="stock" placeholder="Stock" required>
                    <input type="text" id="image" placeholder="Image URL" required>
                </div>

                <textarea id="description" placeholder="Description"></textarea>

                <div class="actions">
                    <button type="button" id="closeBtn">Cancel</button>
                    <button type="submit">Save</button>
                </div>

            </form>
        </div>
    </div>

    <script src="app.js"></script>
</body>
</html>* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: Arial, sans-serif;
  background: #f5f5f5;
}

header {
  background: #fff;
  padding: 15px 30px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2px 10px rgba(0,0,0,.1);
}

header button {
  padding: 10px 20px;
  border: none;
  background: #111;
  color: white;
  border-radius: 6px;
  cursor: pointer;
}

#cards {
  width: 90%;
  margin: 30px auto;
  display: grid;
  grid-template-columns: repeat(auto-fill,minmax(280px,1fr));
  gap: 20px;
}

.card {
  background: white;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 2px 10px rgba(0,0,0,.1);
}

.card img {
  width: 100%;
  height: 200px;
  object-fit: cover;
}

.card-content {
  padding: 15px;
}

.card h3 {
  margin-bottom: 10px;
}

.card p {
  color: #666;
  margin-bottom: 10px;
}

.price {
  font-size: 22px;
  font-weight: bold;
}

.stock {
  color: green;
  margin: 10px 0;
  display: block;
}

.btns {
  display: flex;
  gap: 10px;
}

.edit {
  padding: 8px 14px;
  border: none;
  border-radius: 5px;
  cursor: pointer;
}

.delete {
  padding: 8px 14px;
  border: none;
  border-radius: 5px;
  cursor: pointer;
  background: crimson;
  color: white;
}

.modal {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,.5);
  display: none;
  justify-content: center;
  align-items: center;
}

.modal.active {
  display: flex;
}

.modal-content {
  width: 500px;
  background: white;
  border-radius: 10px;
  padding: 20px;
}

.modal-content h3 {
  margin-bottom: 20px;
}

.modal-content input,
.modal-content textarea {
  width: 100%;
  padding: 10px;
  margin-bottom: 15px;
}

.row {
  display: flex;
  gap: 10px;
}

.actions {
  display: flex;
  justify-content: flex-end;
  gap: 10px;
}

.actions button {
  padding: 10px 18px;
  cursor: pointer;
}const API = "https://6a3699be766b831960f9638e.mockapi.io/products";

const cards = document.getElementById("cards");
const modal = document.getElementById("modal");
const form = document.getElementById("form");
const addBtn = document.getElementById("addBtn");
const closeBtn = document.getElementById("closeBtn");
const modalTitle = document.getElementById("modalTitle");

const nameInput = document.getElementById("name");
const categoryInput = document.getElementById("category");
const priceInput = document.getElementById("price");
const stockInput = document.getElementById("stock");
const imageInput = document.getElementById("image");
const descriptionInput = document.getElementById("description");

let editId = null;

addBtn.onclick = () => {
  modal.classList.add("active");
  form.reset();
  editId = null;
  modalTitle.textContent = "Add Product";
};

closeBtn.onclick = () => {
  modal.classList.remove("active");
};

async function getProducts() {
  const res = await fetch(API);
  const data = await res.json();

  cards.innerHTML = "";

  data.forEach(product => {
    cards.innerHTML += `
      <div class="card">
        <img src="${product.image}" alt="">
        
        <div class="card-content">
          <h3>${product.name}</h3>
          <p>${product.category}</p>
          <p>${product.description}</p>

          <div class="price">$${product.price}</div>

          <span class="stock">
            ${product.stock} in stock
          </span>

          <div class="btns">
            <button class="edit" onclick="editProduct('${product.id}')">
              Edit
            </button>

            <button class="delete" onclick="deleteProduct('${product.id}')">
              Delete
            </button>
          </div>
        </div>
      </div>
    `;
  });
}

async function deleteProduct(id) {
  await fetch(`${API}/${id}`, {
    method: "DELETE"
  });

  getProducts();
}

async function editProduct(id) {
  const res = await fetch(`${API}/${id}`);
  const product = await res.json();

  nameInput.value = product.name;
  categoryInput.value = product.category;
  priceInput.value = product.price;
  stockInput.value = product.stock;
  imageInput.value = product.image;
  descriptionInput.value = product.description;

  editId = id;

  modalTitle.textContent = "Edit Product";
  modal.classList.add("active");
}

form.addEventListener("submit", async e => {
  e.preventDefault();

  const product = {
    name: nameInput.value,
    category: categoryInput.value,
    price: priceInput.value,
    stock: stockInput.value,
    image: imageInput.value,
    description: descriptionInput.value,
    isActive: true
  };

  if (editId) {
    await fetch(`${API}/${editId}`, {
      method: "PUT",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify(product)
    });
  } else {
    await fetch(API, {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify(product)
    });
  }

  modal.classList.remove("active");
  form.reset();
  getProducts();
});

getProducts();
