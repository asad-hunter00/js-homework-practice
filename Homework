app.js

```js
const API = "https://6a3699be766b831960f9638e.mockapi.io/contacts"

const cards = document.getElementById("cards")
const form = document.getElementById("form")

const nameInput = document.getElementById("name")
const emailInput = document.getElementById("email")
const phoneInput = document.getElementById("phone")
const companyInput = document.getElementById("company")

let editId = null

function getContacts(){

    fetch(API)
    .then(function(res){
        return res.json()
    })
    .then(function(data){

        cards.innerHTML = ""

        data.forEach(function(item){

            cards.innerHTML += `
            <div class="card">
                <h3>${item.name}</h3>
                <p>${item.email}</p>
                <p>${item.phone}</p>
                <p>${item.company}</p>

                <div class="actions">

                    <button onclick="favoriteContact('${item.id}', ${item.isFavorite})">
                        ${item.isFavorite ? "⭐" : "☆"}
                    </button>

                    <button onclick="editContact('${item.id}')">
                        Edit
                    </button>

                    <button onclick="deleteContact('${item.id}')">
                        Delete
                    </button>

                </div>
            </div>
            `
        })
    })
}

form.addEventListener("submit", function(e){

    e.preventDefault()

    let contact = {
        name: nameInput.value,
        email: emailInput.value,
        phone: phoneInput.value,
        company: companyInput.value,
        avatar: "",
        isFavorite: false
    }

    if(editId){

        fetch(API + "/" + editId,{
            method:"PUT",
            headers:{
                "Content-Type":"application/json"
            },
            body:JSON.stringify(contact)
        })
        .then(function(){
            getContacts()
        })

        editId = null

    }else{

        fetch(API,{
            method:"POST",
            headers:{
                "Content-Type":"application/json"
            },
            body:JSON.stringify(contact)
        })
        .then(function(){
            getContacts()
        })

    }

    form.reset()
})

function deleteContact(id){

    fetch(API + "/" + id,{
        method:"DELETE"
    })
    .then(function(){
        getContacts()
    })
}

function favoriteContact(id,favorite){

    fetch(API + "/" + id,{
        method:"PATCH",
        headers:{
            "Content-Type":"application/json"
        },
        body:JSON.stringify({
            isFavorite: !favorite
        })
    })
    .then(function(){
        getContacts()
    })
}

function editContact(id){

    fetch(API + "/" + id)
    .then(function(res){
        return res.json()
    })
    .then(function(data){

        nameInput.value = data.name
        emailInput.value = data.email
        phoneInput.value = data.phone
        companyInput.value = data.company

        editId = data.id
    })
}

getContacts()
```
