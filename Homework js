// 9️⃣ capitalizeLetters nomli funksiya yozing, ushbu funksiya letters degan array olsin, arraydagi har bitta so'zning faqat bosh harfini katta qilsin.

function capitalizeLetters(letters) {
  return letters.map(
    word => word.charAt(0).toUpperCase() + word.slice(1).toLowerCase()
  );
}

console.log(capitalizeLetters(["jasur", "malika", "bobur"]));


// 🔟 nameLengths nomli funksiya yozing. Berilgan names arraydagi ismlarning uzunligini boshqa arrayda qaytarsin.

function nameLengths(names) {
  return names.map(name => name.length);
}

console.log(nameLengths(["John", "Alice", "Bob", "Eve"]));
