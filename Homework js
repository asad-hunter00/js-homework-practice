// 4️⃣ findById(products, id) funksiyasini yarating. Bu funksiya find yordamida id bo'yicha mahsulotni topadi. Topilsa, mahsulot ma'lumotlarini template literal bilan chiqaring. Topilmasa, topilmadi xabarini chiqaring.

const products2 = [
  { id: 1, name: "Monitor", price: 2500000 },
  { id: 2, name: "Klaviatura", price: 150000 },
  { id: 3, name: "Sichqoncha", price: 80000 }
];

function findById(products, id) {
  const product = products.find(product => product.id === id);

  if (product) {
    console.log(`${product.name} - ${product.price} so'm`);
  } else {
    console.log("Mahsulot topilmadi");
  }
}

findById(products2, 2);


// 5️⃣ Faol (isActive: true) va bahosi 70 dan yuqori bo'lgan talabalarni filtrlang.

const students = [
  { name: "Zulfiya", grade: 85, isActive: true },
  { name: "Kamol", grade: 60, isActive: true },
  { name: "Dildora", grade: 90, isActive: false },
  { name: "Sherzod", grade: 75, isActive: true }
];

const activeStudents = students.filter(
