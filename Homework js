console.log(activeStudents);


// 6️⃣ Sizda blog postlari ro'yxati bor. map yordamida HTML ga shu postlarni card lar ko'rinishida chiqaring.

const posts = [
  { title: "React nima?", author: "Jasur", date: "2024-01-15" },
  { title: "JS asoslari", author: "Malika", date: "2024-02-20" },
