console.log(cards.join(""));


// 7️⃣ map yordamida har bir mahsulotda asl narx va chegirma narxi (20% chegirma) bo'lgan yangi array yarating. Yangi arraydagi obyektlarga discountedPrice property qo'shiladi.

const products3 = [
  { name: "Kamera", price: 3000000 },
  { name: "Quloqchin", price: 500000 },
  { name: "Soat", price: 1200000 }
];

const discountedProducts = products3.map(product => ({
  ...product,
  discountedPrice: product.price * 0.8
}));

console.log(discountedProducts);


